trigger1 = 1
v = 45
range = 0,70
ignorehitpause = 1

[State 40, AI range attack]
type = VarSet
trigger1 = movetype != A;stateno < 50 && time > 4
fvar(39) = 0

[State 0, VarSet]
type = VarSet
trigger1 =  stateno != [421,422]
var(28) = 0

[State 28, no Clash]
type = VarSet
trigger1 =  stateno = [421,422]
var(28) = 1
;----------------------------------------------------------------

[State 0, VarSet]
type = VarSet
trigger1 = statetype != A
var(4) = 1 


[State 0, AssertSpecial]
