flag2 = noairguard
 
    
;----------------------------------------------------------------------------------------------------------------------------------
;----------------------------------------------------------------------------------------------------------------------------------
 ;===============================================================================
; BLOCO DE VARS DE CLASH E HITBOX OFENSIVA
;===============================================================================

;-----------------------------------
; Desativa var(18) quando fora de ataque válido
;-----------------------------------
[State 18, Var18 Off]
type = VarSet
trigger1 = stateno < 100   || stateno = 360                 ; fora de ataques principais
trigger2 = movetype != A                   ; não está atacando
trigger3 = numhelper(7800)
trigger3 = helper(7800), stateno = [7799,7798]
trigger4 = var(19) = 1 || enemy,var(19) = 1
v = 18
value = 0 

;-----------------------------------
; Ativa var(18) nos frames ativos dos ataques
; (Exemplo: cada estado tem seu timing específico de hitbox ativa)
;----------------------------------- 

;-----------------------------------
; Define var(19) = 0 (Clash OFF)
;-----------------------------------
[State 19, Var19 Off]
type = VarSet
triggerall = roundstate = 2
trigger1 = stateno < 200                   ; fora de ataques ofensivos
trigger2 = pos Y < 0                       ; está no ar
trigger3 = stateno = 300
trigger5 = stateno = 201 && p2stateno = 201     
trigger4 = var(20) = 0              ; estado de neutralização
v = 19
value = 0
ignorehitpause= 1

[State 0, VarSet]
type = Varadd
triggerall = var(20) > 0
trigger1 = gametime%1 = 0
v = 20    ;fv = 10
value = -1
ignorehitpause = 1 

[State 19, Vel]
type = velset
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = (-vel X) -1- (p2bodydist X < 140)*3 - (p2bodydist X < 30)*5;player = 90,90
ignorehitpause = 1

[State 19, Vel]
type = posadd
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = 0- (p2bodydist X < 140)*3 - (p2bodydist X < 50)*6;player = 90,90
ignorehitpause = 1
[State 19, Vel]
type = velmul
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = .8
persistent = 4
ignorehitpause = 1
[State 19, Vel]
type = posadd
trigger1 = var(20) > 0 ; && AnimElemTime(0) < 4
x = -2;(-vel X*2);var(5)/2;player = 90,90
ignorehitpause = 1
[State 19, width]
type = width
trigger1 = var(20) =  1 ; && AnimElemTime(0) < 4
value = 50,0;(-vel X*2);var(5)/2;player = 90,90
ignorehitpause = 1

;-----------------------------------
; Define var(19) = 1 (Clash ON)
; Ativado quando há colisão ativa entre ataques de ambos os lados
;-----------------------------------
[State 19, Var19 On]
type = VarSet
triggerall = var(20) > 0
triggerall = roundstate = 2
triggerall = movetype = A 
trigger1 = movereversed &&  enemy, movereversed
v = 19
value = 1
ignorehitpause = 1
 
