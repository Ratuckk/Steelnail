;-------------------------------------------------------------------------------
; Boss stagger bar
[Statedef 72]  
sprpriority = 2
facep2 = 1


[State 0, Turn]
type = Turn 
trigger1 = root, facing != facing
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag =  Invisible
ignorehitpause = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
time = -1
pos = 0,0
ignorehitpause = 1
 
[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP 
slot = 0
stateno = 73
time = 1
forceair = 0 

[State 0, NotHitBy]
type = HitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP 
time = -1 ; mantém ativo sempre
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1;parent,var(28) = 0 || enemy,var(28) = 0
value = Root, anim
elem = Root, AnimelemNO(0)
ignorehitpause = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = numhelper(72) > 1
ignorehitpause = 1

;-------------------------------------------------------------------------------
; Stagger bar Hit
[Statedef 73]  
sprpriority = 2
facep2 = 1


[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NT,ST,HT
time = -1 ; mantém ativo sempre
ignorehitpause = 1


[State 0, Turn]
type = Turn 
trigger1 = root, facing != facing
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag =  Invisible
ignorehitpause = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
time = -1
pos = 0,0
ignorehitpause = 1

[State 0, ParentVarAdd]
type = ParentVarAdd
trigger1 = !hitover && time = 0
fvar(15) = -1 - GetHitVar(damage) + 5


[State 0, ParentVarAdd]
type = ParentVarAdd
trigger1 = time = 0;!hitover && time = 0
fvar(16) = 5


[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1;parent,var(28) = 0 || enemy,var(28) = 0
value = 9999
ignorehitpause = 1

[State 0, DestroySelf]
type = changestate
trigger1 = root,fvar(15) > 0
trigger1 = time = 3
value = 72
ignorehitpause = 1

[State 0, DestroySelf]
type = changestate
trigger1 = root,fvar(15) <= 0 
value = 74
ignorehitpause = 1


