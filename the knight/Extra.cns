[StateDef -2]
 

[State 0, PowerAdd]
type = PowerAdd
trigger1 = helper(7800),stateno = 7798
value = 30



[State 0, Land]
type = Explod
trigger1 = time%13 = 0
trigger1 = var(8) > 0;= 71;animelem = 2;time = 1
anim = 30301;80011; 41101
ID = 88866;cond(enemy,stateno = 372,8836,8837)
pos = 0,-10
postype = p1
facing = 1
vfacing = 1
bindtime = 5
removetime = -2
trans = addalpha 
alpha = 120,255
scale =.02+var(8)*.004,.02+var(8)*.004;.01;1.12
sprpriority = 5
ontop = 0
ownpal = 1
removeongethit = 0
ignorehitpause = 1

[State 0, Land]
type = Explod
trigger1 = NumExplod(6) = 0
trigger1 = time%50 = 0
trigger1 = var(8) >= 74;animelem = 2;time = 1
anim = 30806;80011; 41101
ID = 6;cond(enemy,stateno = 372,8836,8837)
pos = 0,-15
postype = p1
facing = 1
vfacing = 1
bindtime = 5
removetime = -2
scale = .12,.12;1.12
trans = addalpha 
alpha = 120,255
sprpriority = 5
ontop = 0
ownpal = 1
removeongethit = 0
ignorehitpause = 1

[State 0, counting]
type = Varadd
triggerall = roundstate = 2
trigger1 = command = "holdb"; || command = "holdy"
trigger2 = ailevel && random < 210
v = 8   ;fv = 10
value = 2
ignorehitpause =1

[State 0, value max]
type = VarSet
trigger1 = var(8) >= 75;command != "holdz" && command != "holdy"
var(8) = 74
ignorehitpause =1

[State 0, ChangeState]
type = ChangeState
triggerall = roundstate = 2 && stateno != 360 && stateno != [3000,5000]
triggerall = stateno != 208 && stateno != [215,227]
triggerall = stateno != [300,6000]
triggerall = ctrl || (stateno = [200,202]) && movehit || stateno = 210 ;|| stateno = 202
trigger1 = var(8) >= 70 && (command != "holdb"); && command != "holdy") 
trigger2 = var(8) >= 70 && random < 110 && ailevel
trigger2 = stateno = [200,220]
triggerall = stateno != 206 || stateno != 213|| stateno !=[215,240]
value = 208
ctrl = 0 


[State 0, Charge slash var]
type = VarSet
trigger1 = command != "holdb" && !ailevel; && command != "holdy"
trigger2 = stateno = [4000,5500]
trigger3 = stateno = 360
var(8) = 0
ignorehitpause =1


[State -2,デバッグ表示・上（武器あり）]
type = DisplayToClipboard
triggerall = !Ishelper
trigger1 = 1;var(1) = 1
text = "Distance X = %d,Y = %d, VEL X = %d  VEL Y = %d,var(8) = %d, var(50) = %d"
params = floor(P2BodyDist X),floor(P2BodyDist Y),VEL x, vEL y,var(8), var(50)
IgnoreHitPause = 1 

[State 7800, Clash Helper]
type		= Helper 
triggerall      = !ishelper 
triggerall = numhelper(7800) = 0
triggerall = roundstate = 2
trigger1        = 1
helpertype	= Normal
name		= "Clash Hit System"
id		= 7800
pos             = 0,0
postype         = p1
facing		= 1
stateno		= 7799
ownpal		= 1
ignorehitpause  = 1
supermovetime = 99
pausemovetime = 99
size.air.back = 35
size.air.front = 35
size.ground.back = 35
size.ground.front = 35
size.head.pos = 60
size.mid.pos = 30 


 ;===============================================================================
; BLOCO DE VARS DE CLASH E HITBOX OFENSIVA
;===============================================================================

;-----------------------------------
; Desativa var(18) quando fora de ataque válido
;-----------------------------------
[State 18, Var18 Off]
type = VarSet
trigger1 = stateno < 100   || stateno = 360                 ; fora de ataques principais
trigger2 = movetype != A                   ; não está atacando
trigger3 = numhelper(7800)
trigger3 = helper(7800), stateno = [7799,7798]
trigger4 = var(19) = 1 || enemy,var(19) = 1
v = 18
value = 0 

;-----------------------------------
; Ativa var(18) nos frames ativos dos ataques
; (Exemplo: cada estado tem seu timing específico de hitbox ativa)
;----------------------------------- 

;-----------------------------------
; Define var(19) = 0 (Clash OFF)
;-----------------------------------
[State 19, Var19 Off]
type = VarSet
triggerall = roundstate = 2
trigger1 = stateno < 200                   ; fora de ataques ofensivos
trigger2 = pos Y < 0                       ; está no ar
trigger3 = stateno = 300
trigger5 = stateno = 201 && p2stateno = 201     
trigger4 = var(20) = 0              ; estado de neutralização
v = 19
value = 0
ignorehitpause= 1

[State 0, VarSet]
type = Varadd
triggerall = var(20) > 0
trigger1 = gametime%1 = 0
v = 20    ;fv = 10
value = -1
ignorehitpause = 1 

[State 19, Vel]
type = velset
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = (-vel X); -1- (p2bodydist X < 140)*1 - (p2bodydist X < 30)*1;player = 90,90
ignorehitpause = 1

[State 19, Vel]
type = posadd
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = 0- (p2bodydist X < 140)*2 - (p2bodydist X < 50)*2;player = 90,90
ignorehitpause = 1
[State 19, Vel]
type = velmul
trigger1 = var(20) > 0 ;&& AnimElemTime(0) < 4
x = .8
persistent = 4
ignorehitpause = 1 
[State 19, width]
type = width
trigger1 = var(20) =  1 ; && AnimElemTime(0) < 4
value = 50,0;(-vel X*2);var(5)/2;player = 90,90
ignorehitpause = 1

;-----------------------------------
; Define var(19) = 1 (Clash ON)
; Ativado quando há colisão ativa entre ataques de ambos os lados
;-----------------------------------
[State 19, Var19 On]
type = VarSet
triggerall = var(20) > 0
triggerall = roundstate = 2
triggerall = movetype = A 
trigger1 = movereversed &&  enemy, movereversed
v = 19
value = 1
ignorehitpause = 1
 
;----------------------------------- 
;-----------------------------------------------------------------------------------------------------------------------------------
 


;-------------------------------------------------------------------------------
; SPARRING MODE – ATIVAR (quando está em desvantagem)
;-------------------------------------------------------------------------------
[State 0, Sparring Activate]
type = VarSet
triggerall = movetype = I
triggerall = ailevel && var(29) = 0
trigger1 = power < enemy,power || var(48) < enemy,var(48) || life < enemy,life
trigger1 = pos Y >= -20
trigger2 = prevstateno = 360
var(29) = 45 + random%210


;-------------------------------------------------------------------------------
; SPARRING MODE – CONTAGEM REGRESSIVA
;-------------------------------------------------------------------------------
[State 0, Sparring Countdown]
type = VarAdd
triggerall = var(29) > 0
triggerall = movetype != H
trigger1 = 1
var(29) = -1
persistent = 1


;-------------------------------------------------------------------------------
; SPARRING MODE – CANCELAR (situações ruins p/ clash)
;-------------------------------------------------------------------------------
[State 0, Sparring Cancel]
type = VarSet
triggerall = var(29) > 0
triggerall = statetype = A
trigger1 = 1
var(29) = 0
persistent = 1

[State 0, Sparring Cancel]
type = VarSet
triggerall = var(29) > 0
triggerall = p2bodydist X > 300
trigger1 = 1
var(29) = 0
persistent = 1

[State 0, Sparring Cancel]
type = VarSet
triggerall = var(29) > 0
triggerall = p2stateno = 360 || p2stateno = [5000,5500]
trigger1 = 1
var(29) = 0
persistent = 1


;-------------------------------------------------------------------------------
; SPARRING MODE – BOOST DE AÇÃO (gera o HIT CLASH cinematográfico)
;-------------------------------------------------------------------------------
[State 0, Sparring Aggro Boost]
type = ChangeState
triggerall = ailevel
triggerall = var(29) > 0         ; Sparring ativo
triggerall = ctrl
triggerall = p2bodydist X <= 110
triggerall = enemynear, movetype = A || enemynear, movetype = I
trigger1 = random < 600          ; Chance de reagir agressivamente
value = 200                      ; ATAQUE RÁPIDO PRINCIPAL (substitua pelo seu)


;===============================================================================
; IA - Lógica de Movimento Estratégico
; Calcula as intenções de movimentação em var(30)~var(33)
;===============================================================================

[State -1, IA - Desejo de subir]
type = VarSet
triggerall = ailevel
trigger1 = (Enemy, StateType = S || Enemy, StateType = C) && (P2BodyDist Y = [-90, 0])
var(30) = 1

[State -1, IA - Desejo de descer]
type = VarSet
triggerall = ailevel && Pos Y < 0
trigger1 = P2MoveType = A && P2BodyDist Y = [-90, -10]
var(31) = 1

[State -1, IA - Desejo de avançar]
type = VarSet
triggerall = ailevel 
trigger1 = Enemy, MoveType != A || random < 300 || p2movetype = A && enemy,vel X > 7
var(32) = 1

[State -1, IA - Desejo de recuar]
type = VarSet
triggerall = ailevel
trigger1 = P2MoveType = A  && enemy,vel X < 7
var(33) = 1
;==========================================================================
 



[State 5050, 5]; Recover in mid air
type = ChangeState
triggerall = hitover = 1 && (stateno != [5000,5009]) && stateno = [5000,5500]
triggerall = alive ;&& CanRecover =1
trigger1 = 1;Command = "recovery" && !ailevel
trigger2 = ailevel && random > life
value = cond(pos Y >= 0,117,116) ;HITFALL_AIRRECOVER

[State 0, Pogovar]
type = VarSet
trigger1 = stateno != 204
trigger2= stateno = 204 && movecontact;movehit 
fvar(1) = 0


[State 0, VelSet após contato]
type = velset
triggerall = fvar(1) = 1
trigger1 = movecontact || movereversed || enemy, movereversed 
y = -8
ignorehitpause = 1


[State 0, Air dash var]
type = VarSet
trigger1 = pos Y = 0
fvar(8) = 0
ignorehitpause = 1


[State 0, Air dash var]
type = VarSet
trigger1 = stateno = 111 || stateno = 110;pos Y = 0
fvar(8) = 1
ignorehitpause = 1



[State 0, VarSet]
type = VarSet
trigger1 = RoundNo = 1 && roundstate = 4 && LoseKO = 1 && power > 2500
v = 50
value = 1

[State 0, Helper]
type = Helper
trigger1 = RoundNo = 2 && power > 2500 && RoundState = 2 && var(50) = 1 && NumHelper(300) = 0
helpertype = Normal
name = "shade"
ID = 300
stateno = 299
pos = 0,-200
postype = P1
facing = 1
keyctrl = 0
ownpal = 0
supermovetime = 40
pausemovetime = 40
size.xscale = const(size.xscale)
size.yscale = const(size.yscale)
size.ground.back = 20
size.ground.front = 20
size.air.back = 20
size.air.front = 20
size.height = 8
ignorehitpause = 1

[State 0, VarSet]
type = VarSet
trigger1 = RoundNo = 2&& roundstate = 2; && LoseKO = 1
v = 50
value = 0
   
;===============================================================================
; SISTEMA DE MÁSCARAS E STAGGER
; Vars: 
;   47 = Dano recebido
;   48 = Máscaras restantes
;   49 = Flag de Stagger
;   43 = Timer de FX
;   42 = Recharger de máscara 
;===============================================================================
;-------------------------------------------------------------------------------
; FORÇA MUDANÇA DE ESTADO (quando Stagger está ativo)
;-------------------------------------------------------------------------------
[State 0, Forçar ChangeState Stagger]
type = ChangeState
triggerall = alive
triggerall = time <= 3
triggerall = stateno = [5000,5500]
trigger1 = var(49) = 1
value = 4997
ctrl = 0
ignorehitpause = 1


;-------------------------------------------------------------------------------
; SISTEMA DE RECHARGE DE MÁSCARAS (Var 42)
;-------------------------------------------------------------------------------
[State 0, Reset Recharger]
type = VarSet
trigger1 = stateno != 540
trigger2 = var(42) >= 10
trigger3 = var(48) = 5
var(42) = 0

[State 0, Incrementa Recharger]
type = VarAdd
trigger1 = stateno = 540 && time%9 = 0
var(42) = 1
ignorehitpause = 1


;-------------------------------------------------------------------------------
; RESETS INICIAIS (quando entra em Stagger ou RoundState reseta)
;-------------------------------------------------------------------------------
[State -2, Flag de Stagger]
type = VarSet
triggerall = stateno = [5000,5500]
trigger1 = var(48) = 0 && time = 1
var(49) = 1

[State -2, Reset Vars - Início do round]
type = VarSet
trigger1 = RoundState = 0
var(47) = 0 

[State -2, Reset Vars - Início do round]
type = VarSet
trigger1 = RoundState = 0
var(48) = 5


;-------------------------------------------------------------------------------
; CONTROLE DE DANO RECEBIDO
;-------------------------------------------------------------------------------
[State -2, Receber dano]
type = VarAdd
triggerall = stateno = [5000,5500]
trigger1 = !hitover && time = 0
var(47) = 1 + GetHitVar(damage)
[State -2, Receber dano]
type = VarAdd
triggerall = stateno = [5002,5009]
trigger1 = time = 0
var(47) = 55;1 + GetHitVar(damage)



 
;-------------------------------------------------------------------------------
; SISTEMA DE QUEBRA DE MÁSCARAS (FX timer + reset de dano)
;-------------------------------------------------------------------------------
[State -2, Ativar FX Timer]
type = VarSet
trigger1 = var(47) >= 200
var(43) = 15
ignorehitpause = 1

[State -2, Reset FX Timer]
type = VarSet
trigger1 = var(43) < 0
trigger2 = stateno = 4997
var(43) = 0
ignorehitpause = 1

[State -2, Resetar dano após quebra]
type = VarSet
trigger1 = var(47) >= 200 && time = 0
var(47) = 0
ignorehitpause = 1


;-------------------------------------------------------------------------------
; HELPER DAS MÁSCARAS (HUD)
;-------------------------------------------------------------------------------
