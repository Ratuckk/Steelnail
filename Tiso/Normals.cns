;-------------------------------------------------------------------------------
; LIGHT NORMAL 
;-------------------------------------------------------------------------------
[Statedef 200, Light Normal]
type        = U
movetype    = A
physics     = N
juggle      = 1
ctrl        = 0
anim        = 200
poweradd    = 20
sprpriority = 2
facep2      = 1


[State 0, VelSet]
type = VelSet
trigger1 = movehit = 1 && pos Y < 0  && enemy,pos Y < 0
x = 6
y = -3


 [State 18, ChangeAnim em Clash]
type = ChangeAnim
triggerall = time  < 4
trigger1 = enemy, var(18) = 1
value = 200
elem = 3
ignorehitpause = 1
persistent = 0

[State 18, NotHitBy Curto]
type = NotHitBy
trigger1 = animelem = 3 || time = 8; || enemy,var(18) = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 5
ignorehitpause = 1

;-------------------------------------------------------------------------------
; VARIÁVEIS INICIAIS
;-------------------------------------------------------------------------------
