
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, VarSet]
type = varset
trigger1 = time = 0
var(0) = 0
[State 0, VarSet]
type = Varrandom
trigger1 = time = 1;var(0) := 0
v= 0
range = 0,1
       
;Ģ¬ÉgāoāO¢hÄ~
[State 0, DestroySelf]
type = DestroySelf
trigger1 = IsHelper

[State 0, 1]
type = ChangeAnim
triggerall = time = 2
trigger1 = Anim != var(0) && Anim != 5 
value = var(0)
[State 0, 1]
type = ChangeAnim 
trigger1 = Anim != var(0) && Anim != 5 
trigger2 = anim = 5 && animtime = 0 
value = var(0)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

