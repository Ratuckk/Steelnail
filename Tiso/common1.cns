; AGUARDHIT (shaking)
[Statedef 154]
type    = A
movetype= H
physics = N
velset = 0,

[State 50, Gravidade]
type = Gravity
trigger1 = pos Y < -10
ignorehitpause = 1

[State 50, Corrigir Y (Pos)]
type = PosSet
trigger1 = pos Y >= 0
y = 0
ignorehitpause = 1

[State 50, Corrigir Y (Vel)]
type = VelSet
trigger1 = pos Y >= 0
y = 0
ignorehitpause = 0

[State 5201, 5] ;Blink white
type = PalFX
trigger1 = Time = 0
time = 7
add = 128,128,128 ;256,256,256
[State 0, Turn]
type = Turn
trigger1 =  p2dist X < -20
ignorehitpause = 1

[State 154, 1]
type = ChangeAnim
trigger1 = 1
value = 151

[State 154, 2]
type = ChangeState
triggerall = time > 15
trigger1 = HitShakeOver
