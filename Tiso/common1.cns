;===========================
; NEW - HITC_SLIDE
; Deslize ap¾s hit agachado
;===========================
[Statedef 5011]
type = C
movetype = H
physics = C

[State 5011, Set Vel inicial]
type = HitVelSet
trigger1 = Time = 0
x = 1

[State 5011, ChangeAnim]
type = ChangeAnim
