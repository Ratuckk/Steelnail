;---------------------------------------------------------------------------;-------------------------------------------------------------------------------
; JUMP START - InĒcio da animańŃo de pulo com efeitos visuais e variańŃo de impulso
;-------------------------------------------------------------------------------
[Statedef 40, Jump Start]
type        = S
physics     = S
anim        = 40
ctrl        = 0
sprpriority = 1

;-------------------------------------------------------------------------------
; VARI┴VEIS DE DIREŪ├O
;-------------------------------------------------------------------------------
[State 1, Zerar SysVar Direcional]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 2, Direcional Frente]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 3, Direcional Trßs]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

;-------------------------------------------------------------------------------
; VELOCIDADE DE IMPULSO (X e Y)
;-------------------------------------------------------------------------------
[State 4, Velocidade de Pulo]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x))) * ifelse(var(25),1.3,1)
y = const(velocity.jump.y)

[State 5, Impulso Adicional se Correndo]
type = VelAdd
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

