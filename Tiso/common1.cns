trigger1 = AnimTime = 0
x = const(velocity.jump.fwd.x);ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))*ifelse(var(25),1.3,1)
