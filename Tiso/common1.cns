trigger1 = Time = 0
value = 5000

[State 5010, Congelar anim]
type = ChangeAnim
trigger1 = Time > 0
value = anim

[State 5010, Ajuste para estado aķreo]
type = StateTypeSet
triggerall = Time = 0
trigger1 = GetHitVar(yvel) != 0 || GetHitVar(fall)
trigger2 = Pos Y != 0
statetype = A

[State 5010, TransińŃo para slide]
type = ChangeState
trigger1 = HitShakeOver
trigger1 = GetHitVar(yvel) = 0 && !GetHitVar(fall)
