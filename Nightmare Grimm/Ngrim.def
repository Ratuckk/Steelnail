; Definition file for player
; Contains all the filenames needed for the character

; Player information
[Info]
name = "Nightmare King Grimm"        ;Name of character
displayname = "Nightmare King Grimm" ;Name of character to display
versiondate = 01/12/2025   ;Version date of character
mugenversion = 1.1  ;Version of M.U.G.E.N character works on
author = "Ziaker"      ;Character author name
pal.defaults = 1,2,3,4  ;Default palettes in order of preference

; Files for the player
[Files]
cmd     = Ngrim.cmd   ;Command set
cns     = Ngrim.cns   ;Constants
st      = Ngrim.cns   ;States

st1 = Nail.cns
st2 = Extra.cns
st3 = Normals.cns
st4 = Helpers.cns
st5 = projs.cns  
stcommon = common1.cns ;Common states
sprite  = Ngrim.sff   ;Sprite
anim    = Ngrim.air   ;Animation
sound  = Ngrim.snd   ;Sound
;pal1   = player.act   ;Palettes (can have up to 12)
;pal2   =
;pal3   =
;pal4   =
;pal5   =
;pal6   =
;pal7   =
;pal8   =
;pal9   =
;pal10  =
;pal11  =
;pal12  =
