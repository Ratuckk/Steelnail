[Statedef  300, Light Normal]
type        = S                  ; State-type: S-stand, C-crouch, A-air, L-liedown
movetype    = I                 ; Move-type: A-attack, I-idle, H-gethit
physics     = S              ; Physics: S-stand, C-crouch, A-air
juggle      = 1
ctrl        = 0
anim        = 300 
facep2 = 1             ; will allow your back to be turned
hitdefpersist = 0     ; drop all attacks
moveHitPersist = 0 ; Needed for MoveContact to remain true
hitcountpersist = 0 ; Start a new combo
sprpriority = 1      ; Stand behind everything

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim != 300
value = 300
elem = 1
ignorehitpause =1 
persistent = 1


[State -3: Parry Mao]
type		= Helper
triggerall = anim = 300
triggerall = p2stateno = 300
trigger1 = animelem = 2
trigger2 = animelem = 4
trigger3 =  animelem = 6
trigger4 = animelem = 8
helpertype	= Normal
name		= "Clash Hit System" 
pos             = 0,0
postype         = back
facing		= 1
stateno		= 7798
ownpal		= 1
ignorehitpause  = 1
supermovetime = 99
pausemovetime = 99
persistent = 1 

[State 0, Offset]
type = Offset
triggerall = anim = 300
trigger1 = animelemno(0) = 1 || animelemno(0) = 3
triggerall = time > 4
trigger1 = time%3 = 0
x = 6

[State 0, NotHitBy]
type = NotHitBy
trigger1 =1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1
