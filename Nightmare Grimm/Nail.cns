triggerall = anim = 300
trigger1 = 1
persistent = 1

;-------------------------
; Atributos e Prioridade
;-------------------------
attr        = S, NA           ; Standing, Normal Attack
damage      = 40, 20           ; Dano e dano na guarda
animtype    = Light           ; Tipo de animaçăo de ataque
priority    = 3, Hit          ; Prioridade do ataque

;-------------------------
; Flags de Acerto
;-------------------------
guardflag   = MA              ; Como pode ser defendido
hitflag     = M 
  

