ID = 908
pos = 3,-2
postype = p1
facing = 1
vfacing = 1
bindtime = 0
scale = .9,.9
remappal = 1504,palno
removetime = -2
sprpriority = 5
ontop = 0
ownpal = 1
removeongethit = 0

