[State 40, NotHitBy]
type = NotHitBy
trigger1 = 1
value = , NT, ST, HT
 
[State 40, 4]
type = VelSet
triggerall = prevstateno != 100
trigger1 = (p2movetype != A && p2bodydist X >= 100) || (p2stateno = 40 || p2bodydist Y < 0 && enemy,vel Y < -3) || backedgedist < 100 || p2bodydist Y < 0 && p2stateno = [5000,5050]

trigger1 = AnimTime = 0
x = const(velocity.jump.fwd.x);ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))*ifelse(var(25),1.3,1)
y = const(velocity.jump.y)
[State 40, 4]
type = VelSet
triggerall = prevstateno != 100
trigger1 = p2stateno != [5000,5500]
trigger1 = (p2bodydist X = [-20,70]) && BackEdgeDist > 100

trigger1 = AnimTime = 0
x = const(velocity.jump.back.x);ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))*ifelse(var(25),1.3,1)
y = const(velocity.jump.y)

[State 40, 4]
type = VelSet
triggerall = prevstateno != 100 
trigger1 = !((p2movetype != A && p2bodydist X >= 100) || (p2stateno = 40 || p2bodydist Y < 0 && enemy,vel Y < -3))
trigger1 = !(p2movetype = A || p2bodydist X <= 70)

trigger1 = AnimTime = 0
trigger2 = animtime = 0
x =  vel X;const(velocity.jump.back.x);ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))*ifelse(var(25),1.3,1)
y = const(velocity.jump.y)



[State 40, 5]
type = Veladd
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100  
x = const(velocity.runjump.fwd.x)
y = const(velocity.jump.y)

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
;---------------------------------------------------------------------------;-------------------------------------------------------------------------------
; JUMP START - InĒcio da animańŃo de pulo com efeitos visuais e variańŃo de impulso
;-------------------------------------------------------------------------------
[Statedef 40, Jump Start]
type        = S
physics     = S
anim        = 40
ctrl        = 0
sprpriority = 1
facep2 = 1

;-------------------------------------------------------------------------------
; VARI┴VEIS DE DIREŪ├O
;-------------------------------------------------------------------------------
[State 1, Zerar SysVar Direcional]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 2, Direcional Frente]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 3, Direcional Trßs]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

;-------------------------------------------------------------------------------
; VELOCIDADE DE IMPULSO (X e Y)
;-------------------------------------------------------------------------------
[State 4, Velocidade de Pulo]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x))) * ifelse(var(25),1.3,1)
y = const(velocity.jump.y)

[State 5, Impulso Adicional se Correndo]
type = VelAdd
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

;-------------------------------------------------------------------------------
; EFEITOS VISUAIS DE PARTIDA
