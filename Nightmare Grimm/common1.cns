;===========================
; NEW - HITG_SHAKE
; Shake de dano no chŃo com ajuste de tipo de hit
;===========================
[Statedef 5000]
type = S
movetype = H
physics = N
velset = 0,0
anim = 5000

[State 0, ChangeState]
type = ChangeState
trigger1 = ishelper && numhelper(8) = 1
value = 303 
ignorehitpause = 1

[State 5000, Offset]
type = Offset
triggerall = Time < 13
trigger1 = Time % 3 = 0
x = -5

[State 5000, VarRandom - Amplificador de shake]
type = VarRandom
trigger1 = Time < 5
v = 12
range = 3,10

[State 5000, VarRandom - Velocidade de shake]
type = VarRandom
trigger1 = Time < 5
v = 13
range = 3,5

[State 5000, Congelar Anim]
type = ChangeAnim
trigger1 = Time > 0
value = anim

[State 5000, Ajuste para estado aķreo]
type = StateTypeSet
trigger1 = Time = 0
trigger1 = GetHitVar(yvel) != 0 || GetHitVar(fall)
trigger2 = Pos Y != 0
statetype = A

[State 5000, TransińŃo para slide]
type = ChangeState
trigger1 = HitShakeOver
trigger1 = GetHitVar(yvel) = 0 && !GetHitVar(fall)
value = 5001

[State 5000, TransińŃo aķrea]
type = ChangeState
trigger1 = HitShakeOver
value = 5030

[State 5000, Force Feedback - Light]
type = ForceFeedback
trigger1 = anim = 5000 || anim = 5010
persistent = 0
time = 6
waveform = square

[State 5000, Force Feedback - Medium]
type = ForceFeedback
trigger1 = anim = 5001 || anim = 5011
persistent = 0
time = 8
waveform = sinesquare
ampl = 110,-1,-.3

[State 5000, Force Feedback - Hard]
type = ForceFeedback
trigger1 = anim = 5012 || anim = 5002 || anim = 5030
persistent = 0
time = 15
waveform = sinesquare
ampl = 140

