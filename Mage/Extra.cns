triggerall = var(40) = 0 && p2stateno != 421
trigger1 = (p2movetype = I && enemy,time > 5) ||  p2movetype = H  || p2statetype = L || stateno = 422 || stateno = 101 || stateno = 100  || p2stateno = 360; && p2stateno != 421;stateno = 0 || stateno = 52 || prevstateno = [5000,5030];enemy,fvar(39) > 0
var(40) = 0;var(41) ;+ life%20


[State 0, VarAdd]
type = VarAdd
trigger1 = var(40) > 0
var(40) = -1 


