[StateDef -2]

[State 0, PowerAdd]
type = PowerAdd
trigger1 = helper(7800),stateno = 7798
value = 30


[State 0, PowerAdd]
type = PowerAdd 
trigger1 = numhelper(31) = 1
trigger1 = gametime %4 = 0
value = 15 + fvar(15) > 0 * 25
[State 0, PowerAdd]
type = PowerAdd
trigger1 = numhelper(33) = 1  
trigger1 = gametime %4 = 0
value = 15 + fvar(15) > 0 * 25
[State 0, PowerAdd]
type = PowerAdd 
trigger1 =  numhelper(32) = 1  
trigger1 = gametime %4 = 0
value = 15 + fvar(15) > 0 * 25
;------------------------------
; BOSS VAR

[State 0, VarAdd]
type = VarAdd
triggerall = fvar(15) > 0 
triggerall = Teammode = Single
trigger1 = enemy, teammode != Single && enemy, teammode != Turns  
trigger1 = var(1) = 0
v = 1    ;fv = 
value = 1

[State 0, Special Ball]
type = Helper  
triggerall = fvar(15) > 0 
triggerall = Teammode = Single
trigger1 = enemy, teammode != Single && enemy, teammode != Turns  
trigger1 = numhelper(31) = 0 
helpertype = normal
name = "Special"
ID = 31
stateno = 2131;1010;1405+cond(anim=444,2,0)
pos = 30,-135;-65+cond(anim = 444,12,0)
postype = p1
ownpal = 1
size.height =  31
persistent = 0

[State 0, NotHitBy]
type = NotHitBy
triggerall = fvar(15) > 0 
triggerall = Teammode = Single
trigger1 = enemy, teammode != Single && enemy, teammode != Turns
value = SCA,NA,SA,HA,NP,SP,HP
time = 1

[State 0, HitBy]
type = HitBy
triggerall = fvar(15) > 0 
triggerall = Teammode = Single
trigger1 = enemy, teammode != Single && enemy, teammode != Turns
value = SCA,NT,ST,HT 
time = 1 

[State 480, ModifyExplod Infection Bar]
type = ModifyExplod
trigger1 = NumExplod(70) > 0
ID = 70
scale = 0+ ((fvar(15) / 30.0) * .2),.5
ignorehitpause = 1


[State 250, Explod Impacto 2]
type = Explod
triggerall = numexplod(70) = 0
Trigger1 = fvar(15) > 0 ;root,teamside = 1
anim = 80024
ID = 70
facing = 1
pos = -40,-120; -35
postype = p1
bindtime = -1 
removetime = -1 
scale = .3,.5
sprpriority = 8
persistent = 0
ownpal = 1
removeongethit = 0
ignorehitpause = 1
  

[State 0, VarSet]
type = VarSet
triggerall = Teammode = Single
triggerall = enemy, teammode != Single && enemy, teammode != Turns
trigger1 = fvar(15) < 0
fvar(15) = 0
[State 0, VarSet]
type = VarSet 
trigger1 = fvar(16) < 0
fvar(16) = 0

[State 0, VarSet]
type = Varadd 
trigger1 = fvar(16) > 0
fvar(16) = -1

[State 0, ChangeState]
type = ChangeState
triggerall = Teammode = Single
triggerall = enemy, teammode != Single && enemy, teammode != Turns
triggerall = fvar(15) = 0
trigger1 = fvar(16) > 1 && stateno != 71 || numhelper(72) && (helper(72),stateno = 74) && numhelper(72) > 0 && (helper(72),time = [0,5])
value = 71
ctrl = 0


[State 0, Offset]
type = Offset
trigger1 = fvar(16) > 0 && time%3 = 0
x = 5
ignorehitpause = 1
 
[State 0, VarSet]
type = VarSet
triggerall = Teammode = Single
triggerall = enemy, teammode != Single && enemy, teammode != Turns
trigger1 = roundstate = 1  
fvar(15) = 200

[State 0, PalFXWiz]
type = PalFX
trigger1 = fvar(15) > 0 && fvar(16) > 0
time = 6
add = 100,100,100
mul = 256,256,256
sinadd = -80,-80,-80,10
invertall = 0
color = 0



[State 7800, Clash Helper]
type		= Helper 
triggerall = Teammode = Single
triggerall = enemy, teammode != Single && enemy, teammode != Turns
triggerall      = !ishelper 
triggerall = numhelper(72) = 0
