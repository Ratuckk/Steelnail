;-------------------------------------------------------------------------------
; LIGHT NORMAL 1 
;-------------------------------------------------------------------------------
[Statedef 200, Light Normal]
type        = U
movetype    = A
physics     = N
juggle      = 1
ctrl        = 0
anim        = 200
poweradd    = 20
sprpriority = 2
facep2      = 1

;-------------------------------------------------------------------------------
; VARIÁVEIS INICIAIS
;-------------------------------------------------------------------------------
[State 5, Tempo de Blockstun (VarSet 5)]
type = VarSet
trigger1 = time = 0
v = 5
value = 15 

[State 11, Altura do Impacto (VarSet 11)]
type = VarSet
trigger1 = time = 0
v = 11
value = 60


[State 40, AI range attack]
type = VarSet
trigger1 = time = 2
fvar(39) = 100 +  vel X


[State 18, ChangeAnim]
type = ChangeAnim
triggerall = time < 5
trigger1 = enemy, var(18) = 1
value = 200
elem = 3
ignorehitpause = 1
persistent = 0

[State 18, NotHitBy]
type = NotHitBy
trigger1 = animelem = 3 || time = 9
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 4
ignorehitpause = 1

;-------------------------------------------------------------------------------
; VELOCIDADE HORIZONTAL E MOVIMENTO
;-------------------------------------------------------------------------------
[State 100, Velocidade Adicional]
type = Veladd
trigger1 = animelem = 3
x = 3
ignorehitpause = 1

[State 100, Velocidade Máxima]
type = Velset
triggerall = prevstateno != 101
trigger1 = vel X > 6
x = 6
ignorehitpause = 1

[State 100, Multiplicador de Velocidade]
type = VelMul
trigger1 = statetype = S || statetype = C || animelem = 3 > 6
x = 0.9
ignorehitpause = 1

;-------------------------------------------------------------------------------
; GRAVIDADE E CORREÇĂO VERTICAL
;-------------------------------------------------------------------------------
[State 50, Gravidade]
type = Gravity
trigger1 = statetype = A || pos Y < -10
ignorehitpause = 1

[State 50, Corrigir Y (Pos)]
